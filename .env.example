# AEON: Living Worlds — example environment overrides.
# Copy to `.env` (git-ignored) only if you use a tool that loads it. AEON itself is
# configured primarily via config.yaml; these are the few env knobs it reads directly.

# Path to an alternate config file (defaults to ./config.yaml).
# Handy for keeping a personal config out of git:
#   cp config.yaml config.local.yaml   # then:
AEON_CONFIG=config.yaml

# --- Optional: Ollama (local LLM world-spirit) ---
# AEON reads the Ollama base_url and model ids from config.yaml (governor.* / mind.*),
# not from env. Set them there. Listed here only as a reminder of what's involved:
#   governor.base_url  -> http://localhost:11434
#   governor.model     -> <your small Ollama model>
#   mind.teacher_model -> <your large Ollama model>

# No API keys, tokens, or secrets are required to run AEON.
